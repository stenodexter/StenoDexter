# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# =========================
# 🔐 Auth (Better Auth)
# =========================
BETTER_AUTH_SECRET="your_better_auth_secret"
JWT_SECRET="your_jwt_secret"

BETTER_AUTH_BASE_URL="http://localhost:3000"

BETTER_AUTH_GOOGLE_CLIENT_ID="your_google_client_id"
BETTER_AUTH_GOOGLE_CLIENT_SECRET="your_google_client_secret"

# =========================
# 🗄️ Database (Drizzle + Postgres)
# =========================
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# =========================
# 💳 Razorpay
# =========================
RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="your_public_razorpay_key_id"

# =========================
# 🧑‍💼 Admin
# =========================
ADMIN_INVITE_CODE="your_admin_invite_code"

# =========================
# ☁️ Cloudflare R2 (S3 Compatible)
# =========================
R2_ACCOUNT_ID="your_r2_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET="your_bucket_name"
R2_PUBLIC_URL="https://your-public-url.r2.dev"

# =========================
# 📩 Email (Resend)
# =========================
RESEND_API_KEY="your_resend_api_key"

# =========================
# 💰 App Config
# =========================
APP_SUBSCRIPTION_PRICE="1500"

# =========================
# 🌍 Environment
# =========================
NODE_ENV="development"

# =========================
# 🌐 Public URL (Frontend access)
# =========================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"